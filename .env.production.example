# --- Payload ---
PAYLOAD_SECRET=__BITTE_ZUFAELLIGEN_64_ZEICHEN_STRING__

# --- Public URL (genau so, inkl. https und ohne trailing slash) ---
NEXT_PUBLIC_SERVER_URL=https://deinefenster.janis-jankewitz.de

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
