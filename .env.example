# ============================================
# Muster Fenster - Environment Variables
# ============================================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/muster_fenster

# --- Payload CMS ---
PAYLOAD_SECRET=your-secret-here-change-in-production

# --- Application ---
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- N8N Webhooks ---
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/...
N8N_WEBHOOK_SECRET=your-webhook-secret

# --- E-Mail Queue Worker ---
# E-Mail Queue Worker sends to this N8N webhook
N8N_EMAIL_WEBHOOK_URL=

# --- Node ---
NODE_ENV=development
